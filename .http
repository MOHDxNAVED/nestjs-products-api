### get all products
GET {{baseUrl}}product
Authorization: {{authToken}}

### find the product using pagination
GET  http://localhost:3000/product?page=2&limit=4
Authorization: {{authToken}}

### create product
POST {{baseUrl}}product
Content-Type: {{contentType}}
Authorization: {{authToken}}

{
  "name": "laptop",
  "description": "Gaming Laptop",
  "price": 75000,
  "isAvailable": true,
  "categoryId":"8a88a59c-3851-42a6-82b1-8c5a8837f2c8"
}


### get one product by Id
GET {{baseUrl}}product/bc6e72c7-e875-41fa-9274-687196c49bb6
Authorization: {{authToken}}

### try to get product with wrong id
GET {{baseUrl}}product/77cd8282-485d-4266-9a59-67699c346ca7
Authorization: {{authToken}}



### Update the product by id
PATCH {{baseUrl}}product/bc6e72c7-e875-41fa-9274-687196c49bb6
Content-Type: {{contentType}}
Authorization: {{authToken}}

{   
    "description": "Samsung"
    
}

### delete product
DELETE {{baseUrl}}product/bc6e72c7-e875-41fa-9274-687196c49bb6
Authorization: {{authToken}}


